    <TextView
        android:id="@+id/tools_feat_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp"
        android:paddingLeft="8dp"
        android:paddingRight="5dp"
        android:text="@string/string_nightly_ttl"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_gravity="left"
        android:fontFamily="@font/noto_serif"/>

    <androidx.cardview.widget.CardView
        xmlns:card_view="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:layout_marginLeft="7dp"
        android:layout_marginRight="7dp"
        card_view:cardCornerRadius="8dp"
        card_view:cardElevation="2dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="206dp"
            android:padding="22dp">

            <TextView
                android:id="@+id/txtSurahNo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SURAH NO. 67"
                android:textColor="@color/text_primary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtSurahName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/txtSurahNo"
                android:layout_marginTop="8dp"
                android:text="Al-Mulk"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="normal" />

            <TextView
                android:id="@+id/txtSurahDesc"
                android:layout_width="230dp"
                android:layout_height="wrap_content"
                android:layout_below="@id/txtSurahName"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="3dp"
                android:text="Protector against the punishment of the grave."
                android:textColor="@color/colorWhite"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/txtVerseInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:text="30 Verses"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />

            <Button
                android:id="@+id/mulk_button"
                android:layout_width="104dp"
                android:layout_height="44dp"
                android:layout_alignParentEnd="true"
                android:layout_alignParentBottom="true"
                android:background="@drawable/bg_card"
                android:text="OPEN  →"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="14sp" />



        </RelativeLayout>

    </androidx.cardview.widget.CardView>


    <androidx.cardview.widget.CardView
        xmlns:card_view="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:layout_marginLeft="7dp"
        android:layout_marginRight="7dp"
        card_view:cardCornerRadius="8dp"
        card_view:cardElevation="2dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="206dp"
            android:padding="22dp">

            <TextView
                android:id="@+id/txtSurahNo1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SURAH NO. 02"
                android:textColor="@color/text_primary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtSurahName1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/txtSurahNo1"
                android:layout_marginTop="8dp"
                android:text="Al-Baqarah"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="normal" />

            <TextView
                android:id="@+id/txtSurahDesc1"
                android:layout_width="230dp"
                android:layout_height="wrap_content"
                android:layout_below="@id/txtSurahName1"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="3dp"
                android:text="The last two verses provide protection for the night."
                android:textColor="@color/colorWhite"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/txtVerseInfo1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:text="Verses 277-286"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />

            <Button
                android:id="@+id/baqara_button"
                android:layout_width="104dp"
                android:layout_height="44dp"
                android:layout_alignParentEnd="true"
                android:layout_alignParentBottom="true"
                android:background="@drawable/bg_card"
                android:text="OPEN  →"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:fontFamily="@font/noto_serif"/>



        </RelativeLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>