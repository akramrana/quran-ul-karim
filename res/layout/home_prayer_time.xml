<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/prayer_times_section"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:visibility="visible">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="10dp"
        android:layout_marginBottom="2dp"
        android:layout_marginTop="15dp"
        app:cardElevation="3dp"
        app:cardCornerRadius="25dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="10dp"
                android:paddingBottom="6dp">

                <TextView
                    android:id="@+id/prayer_time_ttl"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerHorizontal="true"
                    android:text="@string/string_prayer_times"
                    android:textColor="@color/transColor"
                    android:textSize="15sp" />

                <ImageButton
                    android:id="@+id/btnPrayerNotif"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="12dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="Prayer alerts"
                    android:src="@drawable/ic_notifications_none"
                    app:tint="@color/transColor" />

            </RelativeLayout>

            <!--                    <LinearLayout-->
            <!--                        android:layout_width="match_parent"-->
            <!--                        android:layout_height="wrap_content"-->
            <!--                        android:orientation="vertical">-->

            <!--                        <TextView-->
            <!--                            android:id="@+id/prayer_time_ttl"-->
            <!--                            android:layout_width="match_parent"-->
            <!--                            android:layout_height="wrap_content"-->
            <!--                            android:layout_marginLeft="15dip"-->
            <!--                            android:layout_marginTop="10dip"-->
            <!--                            android:gravity="center"-->
            <!--                            android:text="@string/string_prayer_times"-->
            <!--                            android:textColor="@color/transColor"-->
            <!--                            android:textSize="15sp" />-->

            <!--                    </LinearLayout>-->

            <HorizontalScrollView
                android:id="@+id/horizontalScrollView1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_gravity="center"
                    android:paddingBottom="10dp"
                    android:layout_margin="10dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="0.20"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_margin="5dp">

                        <TextView
                            android:id="@+id/fajr_time_ttl"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2.0dip"
                            android:text="@string/string_fajr"
                            android:textSize="13sp"
                            android:textColor="@color/colorWhite"
                            android:gravity="center"
                            android:layout_marginLeft="15dip"/>

                        <TextView
                            android:id="@+id/ftime"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2.0dip"
                            android:text="--:-- --"
                            android:textSize="13sp"
                            android:textColor="@color/colorWhite"
                            android:gravity="center"
                            android:layout_marginLeft="15dip"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="0.20"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_margin="5dp">

                        <TextView
                            android:id="@+id/ztime_ttl"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2.0dip"
                            android:text="@string/string_dhuhr"
                            android:textSize="13sp"
                            android:textColor="@color/colorWhite"
                            android:gravity="center"
                            android:layout_marginLeft="15dip"/>

                        <TextView
                            android:id="@+id/ztime"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2.0dip"
                            android:text="--:-- --"
                            android:textSize="13sp"
                            android:textColor="@color/colorWhite"
                            android:gravity="center"
                            android:layout_marginLeft="15dip"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="0.20"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_margin="5dp">

                        <TextView
                            android:id="@+id/atime_ttl"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2.0dip"
                            android:text="@string/string_asr"
                            android:textSize="13sp"
                            android:textColor="@color/colorWhite"
                            android:gravity="center"
                            android:layout_marginLeft="15dip"/>

                        <TextView
                            android:id="@+id/atime"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2.0dip"
                            android:text="--:-- --"
                            android:textSize="13sp"
                            android:textColor="@color/colorWhite"
                            android:gravity="center"
                            android:layout_marginLeft="15dip"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="0.20"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_margin="5dp">

                        <TextView
                            android:id="@+id/mtime_ttl"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2.0dip"
                            android:text="@string/string_magrib"
                            android:textSize="13sp"
                            android:textColor="@color/colorWhite"
                            android:gravity="center"
                            android:layout_marginLeft="15dip"/>

                        <TextView
                            android:id="@+id/mtime"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2.0dip"
                            android:text="--:-- --"
                            android:textSize="13sp"
                            android:textColor="@color/colorWhite"
                            android:gravity="center"
                            android:layout_marginLeft="15dip"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="0.20"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_margin="5dp">

                        <TextView
                            android:id="@+id/itime_ttl"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2.0dip"
                            android:text="@string/string_isha"
                            android:textSize="13sp"
                            android:textColor="@color/colorWhite"
                            android:gravity="center"
                            android:layout_marginLeft="15dip"/>

                        <TextView
                            android:id="@+id/itime"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2.0dip"
                            android:text="--:-- --"
                            android:textSize="13sp"
                            android:textColor="@color/colorWhite"
                            android:gravity="center"
                            android:layout_marginLeft="15dip"/>

                    </LinearLayout>

                </LinearLayout>

            </HorizontalScrollView>

            <TextView
                android:id="@+id/pr_calc_method"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Based on: Umm al-Qura, Makkah"
                android:gravity="center"
                android:layout_marginBottom="5dp"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>