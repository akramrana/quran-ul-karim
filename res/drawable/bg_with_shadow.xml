<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Main background -->
    <item>
        <shape>
            <solid android:color="@color/bg_color_v2"/>
        </shape>
    </item>

    <!-- Bottom shadow -->
    <item android:bottom="-2dp">
        <shape>
            <gradient
                android:startColor="#20000000"
                android:endColor="@android:color/transparent"
                android:angle="90"/>
        </shape>
    </item>

</layer-list>